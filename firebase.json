{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/invites/accept",
        "function": {
          "functionId": "acceptInviteEndpointV2",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/visits/leave",
        "function": {
          "functionId": "leaveVisitEndpointV2",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/api/visits/delete",
        "function": {
          "functionId": "deleteVisitEndpointV2",
          "region": "southamerica-east1"
        }
      },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
