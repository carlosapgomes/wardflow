rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================
    // Helpers de ACL colaborativa
    // ===============================

    // Usuário autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se usuário é membro ativo da visita
    function isActiveMember(visitId, uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/visits/$(visitId)/members/$(uid))
        && get(/databases/$(database)/documents/visits/$(visitId)/members/$(uid)).data.status == 'active';
    }

    // Verifica se usuário é owner ativo da visita
    function isOwner(visitId, uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/visits/$(visitId)/members/$(uid))
        && get(/databases/$(database)/documents/visits/$(visitId)/members/$(uid)).data.status == 'active'
        && get(/databases/$(database)/documents/visits/$(visitId)/members/$(uid)).data.role == 'owner';
    }

    // Pode editar visita (owner ou editor ativo)
    function canEditVisit(visitId, uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/visits/$(visitId)/members/$(uid))
        && get(/databases/$(database)/documents/visits/$(visitId)/members/$(uid)).data.status == 'active'
        && (get(/databases/$(database)/documents/visits/$(visitId)/members/$(uid)).data.role == 'owner'
            || get(/databases/$(database)/documents/visits/$(visitId)/members/$(uid)).data.role == 'editor');
    }

    // ===============================
    // Colaboração: Visits
    // ===============================
    match /visits/{visitId} {
      // Read: membro ativo
      allow read: if isActiveMember(visitId, request.auth.uid);

      // Create: usuário autenticado criando visita própria
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      // Update/delete: apenas owner
      allow update, delete: if isOwner(visitId, request.auth.uid);

      // Subcoleção: members
      match /members/{memberUserId} {
        // Read: membro ativo da visita
        allow read: if isActiveMember(visitId, request.auth.uid);

        // Create: owner OU bootstrap estrito do owner inicial
        allow create: if isOwner(visitId, request.auth.uid)
          || (
            request.auth.uid == get(/databases/$(database)/documents/visits/$(visitId)).data.userId
            && memberUserId == request.auth.uid
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.visitId == visitId
            && request.resource.data.role == 'owner'
            && request.resource.data.status == 'active'
            && !exists(/databases/$(database)/documents/visits/$(visitId)/members/$(memberUserId))
          );

        // Update/delete: owner
        allow update, delete: if isOwner(visitId, request.auth.uid);
      }

      // Subcoleção: notes
      match /notes/{noteId} {
        // Read: membro ativo
        allow read: if isActiveMember(visitId, request.auth.uid);

        // Create/update: owner ou editor + coerência do visitId
        allow create, update: if canEditVisit(visitId, request.auth.uid)
          && request.resource.data.visitId == visitId;

        // Delete: owner ou editor
        allow delete: if canEditVisit(visitId, request.auth.uid);
      }

      // Subcoleção: invites
      match /invites/{inviteId} {
        // Read/write: apenas owner
        allow read, write: if isOwner(visitId, request.auth.uid);
      }
    }

    // ===============================
    // Notas: hardening com validações
    // ===============================
    match /users/{userId}/notes/{noteId} {
      
      // Owner check: usuário só pode acessar suas próprias notas
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Delete: apenas owner
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Create: validações mínimas de estrutura
      allow create: if request.auth != null 
        && request.auth.uid == userId
        && isValidNoteCreate(request.resource.data, userId, noteId);

      // Update: validações mínimas
      allow update: if request.auth != null 
        && request.auth.uid == userId
        && isValidNoteUpdate(request.resource.data, request.resource.data, userId, noteId);
    }

    // ===============================
    // Outras coleções: owner simples
    // ===============================
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }

  // ===============================
  // Funções de validação
  // ===============================

  // Valida criação de nota
  function isValidNoteCreate(data, pathUserId, noteId) {
    return data.ward is string
      && data.bed is string
      && data.note is string
      && data.date is string
      && data.createdAt is timestamp
      && data.expiresAt is timestamp
      && data.userId == pathUserId
      && data.id == noteId
      && data.ward.size() <= 100
      && data.bed.size() <= 100
      && data.note.size() <= 2000
      && data.date.size() == 10
      && (data.reference == null || (data.reference is string && data.reference.size() <= 100))
      && (data.syncStatus == null || data.syncStatus == 'pending')
      && (data.syncedAt == null || data.syncedAt is timestamp)
      && (data.updatedAt == null || data.updatedAt is timestamp);
  }

  // Valida atualização de nota
  function isValidNoteUpdate(newData, oldData, pathUserId, noteId) {
    return newData.userId == oldData.userId
      && newData.userId == pathUserId
      && newData.id == oldData.id
      && newData.id == noteId
      && (newData.ward == null || (newData.ward is string && newData.ward.size() <= 100))
      && (newData.bed == null || (newData.bed is string && newData.bed.size() <= 100))
      && (newData.note == null || (newData.note is string && newData.note.size() <= 2000))
      && (newData.reference == null || (newData.reference is string && newData.reference.size() <= 100))
      && (newData.date == null || (newData.date is string && newData.date.size() == 10))
      && newData.createdAt == oldData.createdAt
      && (newData.expiresAt == null || newData.expiresAt is timestamp)
      && (newData.updatedAt == null || newData.updatedAt is timestamp);
  }
}
